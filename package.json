{
  "name": "npo-template-merged",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "repository": "git@github.com:ctc-uci/npo-template-merged.git",
  "author": "CTC <ctc@uci.edu>",
  "license": "MIT",
  "scripts": {
    "dev": "yarn tsx concurrently.ts",
    "start": "yarn tsx concurrently.ts",
    "prepare": "husky",
    "test": "node test-runner.js",
    "test:server": "yarn workspace server test",
    "test:client": "yarn workspace client test",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "fix": "yarn format && yarn lint"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@types/lint-staged": "^13.3.0",
    "concurrently": "^10.0.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.24.0"
  },
  "resolutions": {
    "@babel/helpers": "^7.26.10",
    "@remix-run/router": "^1.23.2",
    "ajv": "^6.14.0",
    "brace-expansion": "^1.1.13",
    "cookie": "^0.7.2",
    "cross-spawn": "^7.0.6",
    "d3-color": "^3.1.0",
    "fast-xml-parser": "^5.7.0",
    "flatted": "^3.4.2",
    "lodash": "^4.18.0",
    "minimatch": "^3.1.4",
    "node-forge": "^1.4.0",
    "path-to-regexp": "^0.1.13",
    "picomatch": "^2.3.2",
    "qs": "^6.14.2",
    "react-router": "^6.30.4",
    "semver": "^7.7.2",
    "tmp": "^0.2.6",
    "undici": "^6.24.0",
    "uuid": "^11.1.1",
    "yaml": "^2.8.3"
  },
  "workspaces": {
    "packages": [
      "client",
      "server"
    ],
    "nohoist": [
      "**/firebase",
      "**/firebase/**",
      "**/patch-package",
      "**/patch-package/**",
      "**/postinstall-postinstall",
      "**/postinstall-postinstall/**",
      "**/vite",
      "**/vite/**",
      "**/@vitejs/plugin-react",
      "**/@vitejs/plugin-react/**"
    ]
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.2.4",
    "axios": "^1.16.1",
    "react-icons": "^5.5.0",
    "swr": "^2.4.1"
  }
