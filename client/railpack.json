{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "corepack prepare yarn@1.22.22 --activate",
        "cd .. && yarn install --frozen-lockfile"
      ]
    },
    "build": {
      "commands": ["yarn build"]
    }
  },
  "deploy": {
    "startCommand": "yarn preview:railway"
  }
}
