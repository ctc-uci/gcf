{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "corepack prepare yarn@1.22.22 --activate",
        "YARN_PRODUCTION=false yarn install --frozen-lockfile"
      ]
    },
    "build": {
      "commands": ["yarn workspace npo-client-template build"]
    }
  },
  "deploy": {
    "startCommand": "yarn workspace npo-client-template preview:railway"
  }
}
